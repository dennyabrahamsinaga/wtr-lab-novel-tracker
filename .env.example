## Database
# Local dev (docker-compose): postgresql://postgres:postgres@localhost:5432/wtr_novels?schema=public
DATABASE_URL=

## NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_random_32_plus_character_secret

# GitHub OAuth (recommended)
GITHUB_ID=
GITHUB_SECRET=

# Vercel Cron (recommended in production)
CRON_SECRET=replace_with_a_random_shared_secret

## Web Push (notifications)
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Client-side key (same as VAPID_PUBLIC_KEY)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
